# QuestKeeperAI Backend Configuration
# Copy this file to .env and fill in your actual values

# ================================
# LLM PROVIDER CONFIGURATION
# ================================
# Choose your provider: anthropic, openai, gemini, local
LLM_PROVIDER=gemini

# API Keys (only set the ones you plan to use)
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Local LLM Configuration (for Ollama, vLLM, etc.)
# Only needed if LLM_PROVIDER=local
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=mistral

# ================================
# APPLICATION SETTINGS
# ================================
DEBUG=True
LOG_LEVEL=INFO

# Secret key for session management (generate a random string in production)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Flask server configuration
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5001

# ================================
# DATABASE
# ================================
# Database path (auto-created in user's AppData by default)
# DATABASE_URL=sqlite:///C:/Users/YourUsername/AppData/Local/QuestKeeperAI/game.db

# ================================
# MCP CONFIGURATION
# ================================
# MCP servers directory
# MCP_SERVERS_DIR=C:/Users/YourUsername/AppData/Local/QuestKeeperAI/servers

# MCP timeout (seconds)
# MCP_TIMEOUT_SECONDS=30

# Maximum number of concurrent MCP processes
# MCP_PROCESS_LIMIT=10

# ================================
# GAME SETTINGS
# ================================
# Maximum characters per user
# MAX_CHARACTERS_PER_USER=10

# Auto-save interval (seconds)
# AUTO_SAVE_INTERVAL=300

# Enable automatic backups
# BACKUP_ENABLED=True

# ================================
# NOTES
# ================================
# 1. Uncomment lines (remove #) to override defaults
# 2. Paths use forward slashes (/) on all platforms
# 3. Keep .env file private - never commit it to git
# 4. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
